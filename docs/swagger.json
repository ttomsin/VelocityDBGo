    "definitions": {
        "handlers.CreateCollectionRequest": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "example": "restaurants"
                }
            }
        },
        "handlers.CreateProjectRequest": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "description": {
                    "type": "string",
                    "example": "My first food delivery app"
                },
                "name": {
                    "type": "string",
                    "example": "Foodie"
                }
            }
        },
        "handlers.LoginRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "student@example.com"
                },
                "password": {
                    "type": "string",
                    "example": "password123"
                }
            }
        },
        "handlers.QueryRequest": {
            "type": "object",
            "properties": {
                "filter": {
                    "description": "Example: {\"address.city\": \"London\", \"age\": \"gt:18\"}",
                    "type": "object",
                    "additionalProperties": true
                },
                "limit": {
                    "type": "integer",
                    "example": 10
                },
                "offset": {
